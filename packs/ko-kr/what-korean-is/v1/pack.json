  "lines": [
    {
      "lineId": "L1",
      "text": "한국어는 한글을 써요."
    },
    {
      "lineId": "L2",
      "text": "한글은 소리글자예요."
    },
    {
      "lineId": "L3",
      "text": "글자는 음절 블록으로 보여요."
    },
    {
      "lineId": "L4",
      "text": "안녕하세요는 안전한 첫인사예요."
    },
    {
      "lineId": "L5",
      "text": "요로 끝나면 공손하게 들려요."
    },
    {
      "lineId": "L6",
      "text": "존댓말부터 배우면 안전해요."
    }
  ],
